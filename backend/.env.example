# ScamShield AI — Backend Environment Variables
# Copy this file to .env and fill in the values

# ==========================
# Core Configuration
# ==========================

# Environment: development | staging | production
# Controls: error verbosity, docs endpoint visibility, HSTS headers
ENVIRONMENT=development

# ==========================
# Hugging Face API Token (free tier)
# ==========================
# Get yours at: https://huggingface.co/settings/tokens
# Leave empty to use fallback keyword-based analysis
HF_API_TOKEN=

# ==========================
# Database URL (PostgreSQL)
# ==========================
# Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Local:     postgresql://postgres:password@localhost:5432/scamshield
DATABASE_URL=postgresql://postgres:password@localhost:5432/scamshield

# ==========================
# CORS Origins (comma-separated, NO wildcards in production)
# ==========================
# Development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://scamshield.vercel.app,https://www.scamshield.in

# ==========================
# Server Config
# ==========================
HOST=0.0.0.0
PORT=8000

# ==========================
# Rate Limiting
# ==========================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BURST=10
WS_MAX_CONNECTIONS=50
WS_MAX_MESSAGE_SIZE=4096
